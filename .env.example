# Email transaccional (Resend)
RESEND_API_KEY=re_your_resend_api_key

# Supabase (cliente público — anon key, NO la service_role)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service_role (server-side ONLY — usada por crons para bypassear RLS).
# Encontrá esta key en Supabase → Project Settings → API → service_role.
# Nunca pongas esto en código cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your_service_role_key

# Cron secret — protege /api/cron/* contra invocaciones externas.
# Generá un string random largo (32+ chars), p. ej. `openssl rand -hex 32`.
# Vercel Cron lo envía en header Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=generate_with_openssl_rand_hex_32
